<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OWNERSCAN · 창업 전 진단 키트</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');

:root {
  --brick: #B5472A;
  --brick-dark: #8B3520;
  --cream: #F7F4F0;
  --dark: #111111;
  --card: #1C1C1C;
  --card2: #242424;
  --border: #2E2E2E;
  --soft: #888;
  --danger: #C0392B;
  --warn: #D4820A;
  --ok: #27AE60;
}

* { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

body {
  font-family: 'Noto Sans KR', sans-serif;
  background: var(--dark);
  color: #fff;
  min-height: 100vh;
  font-size: 15px;
  line-height: 1.6;
}

/* PROGRESS */
.progress-wrap {
  position: fixed;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--border);
  z-index: 100;
}
.progress-bar {
  height: 100%;
  background: var(--brick);
  transition: width 0.4s ease;
}

/* SCREENS */
.screen { display: none; min-height: 100vh; }
.screen.active { display: flex; flex-direction: column; }

/* INTRO */
.intro {
  padding: 60px 24px 40px;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}
.intro-top {}
.brand-tag {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--brick);
  margin-bottom: 24px;
  display: block;
}
.intro h1 {
  font-size: 30px;
  font-weight: 900;
  line-height: 1.25;
  margin-bottom: 16px;
  color: #fff;
}
.intro h1 em {
  color: var(--brick);
  font-style: normal;
}
.intro-desc {
  font-size: 14px;
  color: var(--soft);
  line-height: 1.8;
  margin-bottom: 32px;
}
.intro-meta {
  display: flex;
  gap: 20px;
  margin-bottom: 40px;
}
.meta-item {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.meta-label {
  font-size: 10px;
  color: #555;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.meta-value {
  font-size: 14px;
  font-weight: 700;
  color: #ccc;
}
.domains-preview {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  margin-bottom: 40px;
}
.domain-pill {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 12px;
  font-size: 12px;
  color: #aaa;
  display: flex;
  align-items: center;
  gap: 8px;
}
.domain-pill-num {
  width: 18px;
  height: 18px;
  background: var(--brick);
  border-radius: 50%;
  font-size: 10px;
  font-weight: 700;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* BUTTONS */
.btn-primary {
  width: 100%;
  padding: 17px;
  background: var(--brick);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Noto Sans KR', sans-serif;
  transition: background 0.2s;
  letter-spacing: 0.02em;
}
.btn-primary:active { background: var(--brick-dark); }

.btn-secondary {
  width: 100%;
  padding: 15px;
  background: transparent;
  color: var(--soft);
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 14px;
  cursor: pointer;
  font-family: 'Noto Sans KR', sans-serif;
  transition: all 0.2s;
  margin-top: 10px;
}
.btn-secondary:active { background: var(--card); }

/* QUESTION SCREEN */
.q-header {
  padding: 56px 24px 20px;
  border-bottom: 1px solid var(--border);
}
.q-step-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}
.q-domain-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--brick);
}
.q-step-count {
  font-size: 12px;
  color: var(--soft);
}
.q-domain-title {
  font-size: 20px;
  font-weight: 900;
  color: #fff;
  margin-bottom: 4px;
}
.q-domain-desc {
  font-size: 13px;
  color: var(--soft);
}

.q-body {
  flex: 1;
  padding: 24px;
  overflow-y: auto;
}

.question-item {
  margin-bottom: 28px;
}
.question-item:last-child { margin-bottom: 0; }

.question-text {
  font-size: 14px;
  font-weight: 500;
  color: #ddd;
  margin-bottom: 14px;
  line-height: 1.6;
}
.question-num {
  font-size: 11px;
  color: var(--soft);
  margin-bottom: 6px;
  letter-spacing: 0.05em;
}

.scale-wrap {
  display: flex;
  flex-direction: column;
  gap: 8px;
}
.scale-labels {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4px;
}
.scale-label-text {
  font-size: 10px;
  color: #555;
}
.scale-options {
  display: flex;
  gap: 8px;
}
.scale-btn {
  flex: 1;
  aspect-ratio: 1;
  max-width: 56px;
  border: 1.5px solid var(--border);
  background: var(--card);
  border-radius: 8px;
  color: var(--soft);
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Noto Sans KR', sans-serif;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
}
.scale-btn:active { transform: scale(0.95); }
.scale-btn.selected {
  background: var(--brick);
  border-color: var(--brick);
  color: #fff;
}

.q-footer {
  padding: 16px 24px 32px;
  border-top: 1px solid var(--border);
}
.q-footer-note {
  font-size: 12px;
  color: #444;
  text-align: center;
  margin-top: 10px;
}

/* RESULTS */
.result-header {
  padding: 56px 24px 28px;
  background: var(--card);
  border-bottom: 1px solid var(--border);
}
.result-brand {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--brick);
  margin-bottom: 16px;
}
.result-title {
  font-size: 22px;
  font-weight: 900;
  margin-bottom: 20px;
  line-height: 1.3;
}

.total-score-wrap {
  display: flex;
  align-items: flex-end;
  gap: 8px;
  margin-bottom: 8px;
}
.total-score-num {
  font-size: 56px;
  font-weight: 900;
  line-height: 1;
  color: var(--brick);
}
.total-score-denom {
  font-size: 18px;
  color: var(--soft);
  padding-bottom: 8px;
}
.total-score-bar-wrap {
  background: var(--border);
  border-radius: 4px;
  height: 6px;
  margin-bottom: 8px;
  overflow: hidden;
}
.total-score-bar {
  height: 100%;
  background: var(--brick);
  border-radius: 4px;
  transition: width 1s ease;
}
.total-score-label {
  font-size: 13px;
  font-weight: 700;
}
.total-score-label.danger { color: var(--danger); }
.total-score-label.warn { color: var(--warn); }
.total-score-label.ok { color: var(--ok); }

.total-score-desc {
  font-size: 13px;
  color: var(--soft);
  margin-top: 4px;
  line-height: 1.6;
}

.result-body {
  padding: 24px;
}

.domain-result-title {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--soft);
  margin-bottom: 16px;
}

.domain-result-item {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 10px;
}
.domain-result-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10px;
}
.domain-result-name {
  font-size: 14px;
  font-weight: 700;
  color: #ddd;
}
.domain-result-score {
  font-size: 13px;
  font-weight: 700;
}
.domain-result-score.danger { color: var(--danger); }
.domain-result-score.warn { color: var(--warn); }
.domain-result-score.ok { color: var(--ok); }

.domain-bar-wrap {
  background: var(--border);
  border-radius: 4px;
  height: 5px;
  margin-bottom: 8px;
  overflow: hidden;
}
.domain-bar {
  height: 100%;
  border-radius: 4px;
  transition: width 1s ease;
}
.domain-bar.danger { background: var(--danger); }
.domain-bar.warn { background: var(--warn); }
.domain-bar.ok { background: var(--ok); }

.domain-status-text {
  font-size: 11px;
}
.domain-status-text.danger { color: var(--danger); }
.domain-status-text.warn { color: var(--warn); }
.domain-status-text.ok { color: var(--ok); }

.result-cta {
  margin-top: 28px;
  padding: 20px;
  background: var(--card2);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-bottom: 12px;
}
.result-cta-title {
  font-size: 15px;
  font-weight: 700;
  margin-bottom: 8px;
}
.result-cta-desc {
  font-size: 13px;
  color: var(--soft);
  line-height: 1.7;
  margin-bottom: 16px;
}

.kakao-btn {
  width: 100%;
  padding: 15px;
  background: #FEE500;
  color: #3B1D1D;
  border: none;
  border-radius: 8px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'Noto Sans KR', sans-serif;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 10px;
}
.kakao-btn:active { opacity: 0.9; }

.result-footer {
  padding: 0 24px 48px;
}


/* CONTACT FORM */
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 16px;
}
.contact-field {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.contact-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--soft);
}
.contact-input {
  width: 100%;
  padding: 13px 14px;
  background: var(--dark);
  border: 1.5px solid var(--border);
  border-radius: 8px;
  color: #fff;
  font-size: 15px;
  font-family: 'Noto Sans KR', sans-serif;
  outline: none;
  transition: border-color 0.2s;
}
.contact-input:focus {
  border-color: var(--brick);
}
.contact-input::placeholder {
  color: #444;
}

/* TOAST */
.toast {
  position: fixed;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: #333;
  color: #fff;
  padding: 12px 20px;
  border-radius: 8px;
  font-size: 13px;
  opacity: 0;
  transition: all 0.3s;
  pointer-events: none;
  white-space: nowrap;
  z-index: 999;
}
.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* SEPARATOR */
.sep {
  height: 1px;
  background: var(--border);
  margin: 20px 0;
}
</style>
</head>
<body>

<div class="progress-wrap">
  <div class="progress-bar" id="progressBar" style="width:0%"></div>
</div>

<!-- INTRO -->
<div class="screen active" id="screenIntro">
  <div class="intro">
    <div class="intro-top">
      <span class="brand-tag">OWNERSCAN · 무료 진단</span>
      <h1>창업 전<br><em>준비됐는지</em><br>확인하세요</h1>
      <p class="intro-desc">
        실력이 있어도 구조 없이 시작하면 망합니다.<br>
        6개 영역 18문항으로 지금 어디가 부족한지<br>정확하게 확인하세요.
      </p>
      <div class="intro-meta">
        <div class="meta-item">
          <span class="meta-label">소요 시간</span>
          <span class="meta-value">약 5분</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">문항 수</span>
          <span class="meta-value">18문항</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">진단 영역</span>
          <span class="meta-value">6개</span>
        </div>
      </div>
      <div class="domains-preview">
        <div class="domain-pill"><span class="domain-pill-num">1</span>고객 정의</div>
        <div class="domain-pill"><span class="domain-pill-num">2</span>센터 방향</div>
        <div class="domain-pill"><span class="domain-pill-num">3</span>자본 준비도</div>
        <div class="domain-pill"><span class="domain-pill-num">4</span>위치 이해도</div>
        <div class="domain-pill"><span class="domain-pill-num">5</span>모객 계획</div>
        <div class="domain-pill"><span class="domain-pill-num">6</span>운영 구조</div>
      </div>
    </div>
    <div>
      <button class="btn-primary" onclick="startDiagnosis()">진단 시작하기</button>
    </div>
  </div>
</div>

<!-- QUESTION SCREEN -->
<div class="screen" id="screenQuestion">
  <div class="q-header">
    <div class="q-step-info">
      <span class="q-domain-label" id="domainLabel"></span>
      <span class="q-step-count" id="stepCount"></span>
    </div>
    <div class="q-domain-title" id="domainTitle"></div>
    <div class="q-domain-desc" id="domainDesc"></div>
  </div>
  <div class="q-body" id="questionsBody"></div>
  <div class="q-footer">
    <button class="btn-primary" id="nextBtn" onclick="nextDomain()">다음</button>
    <p class="q-footer-note">모든 문항에 응답해야 다음으로 넘어갈 수 있습니다</p>
  </div>
</div>

<!-- RESULTS -->
<div class="screen" id="screenResult">
  <div class="result-header">
    <div class="result-brand">OWNERSCAN · 진단 결과</div>
    <div class="result-title" id="resultTitle"></div>
    <div class="total-score-wrap">
      <div class="total-score-num" id="totalScoreNum">0</div>
      <div class="total-score-denom">/ 90점</div>
    </div>
    <div class="total-score-bar-wrap">
      <div class="total-score-bar" id="totalScoreBar" style="width:0%"></div>
    </div>
    <div class="total-score-label" id="totalScoreLabel"></div>
    <div class="total-score-desc" id="totalScoreDesc"></div>
  </div>

  <div class="result-body">
    <div class="domain-result-title">영역별 준비도</div>
    <div id="domainResults"></div>

    <div class="result-cta">
      <div class="result-cta-title">부족한 부분, 같이 잡아드릴게요</div>
      <div class="result-cta-desc">
        결과에서 보완이 필요한 영역이 있다면 — 창업 전 무료 상담 세션에서 어떻게 채울지 같이 설계해드립니다. 구조를 잡고 시작하는 것과 아닌 것은 완전히 다른 결과로 이어집니다.
      </div>

      <div class="contact-form">
        <div class="contact-field">
          <label class="contact-label">이름</label>
          <input type="text" id="inputName" class="contact-input" placeholder="홍길동" maxlength="20">
        </div>
        <div class="contact-field">
          <label class="contact-label">연락처</label>
          <input type="tel" id="inputPhone" class="contact-input" placeholder="010-0000-0000" maxlength="13">
        </div>
      </div>

      <button class="kakao-btn" onclick="openKakao()">
        💬 진단 결과 보내고 카카오 1:1 상담하기
      </button>

      <button class="btn-secondary" onclick="copyResult()">결과 텍스트 복사</button>
    </div>
  </div>

  <div class="result-footer">
    <button class="btn-secondary" onclick="restartDiagnosis()">다시 진단하기</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ✅ Google Apps Script 배포 URL 여기에 붙여넣기
const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbyXtpymunKsEvjT6o1KOBh9NHPP4cMmt6RuwOA9b5lDizGzACPV2UGZyac82RN-DxZf/exec';

const DOMAINS = [
  {
    id: 'customer',
    label: '영역 1',
    title: '고객 정의',
    desc: '내가 누구를 가장 잘 도울 수 있는지 아는가',
    questions: [
      '내 경력에서 가장 오래 남았던 고객의 유형을 구체적으로 말할 수 있다',
      '내가 가장 잘 해결해준 고객의 문제가 무엇인지 안다',
      '창업 후 도울 타겟 고객이 명확하게 정의되어 있다'
    ]
  },
  {
    id: 'concept',
    label: '영역 2',
    title: '센터 방향',
    desc: '어떤 센터를 만들고 싶은지 구체적인가',
    questions: [
      '만들고 싶은 센터의 콘셉트와 분위기가 머릿속에 명확하다',
      '내 센터가 주변 경쟁 센터와 어떻게 다른지 설명할 수 있다',
      '센터가 고객의 어떤 문제를 해결하는지 한 문장으로 말할 수 있다'
    ]
  },
  {
    id: 'capital',
    label: '영역 3',
    title: '자본 준비도',
    desc: '얼마가 있고 얼마가 필요한지 아는가',
    questions: [
      '창업에 필요한 총 예산(보증금·권리금·인테리어·설비 등)을 계산해본 적 있다',
      '현재 보유 자본이 정확히 얼마인지 안다',
      '부족한 자본을 어떻게 마련할지 구체적인 계획이 있다'
    ]
  },
  {
    id: 'location',
    label: '영역 4',
    title: '위치 이해도',
    desc: '타겟 고객이 많은 상권을 파악하고 있는가',
    questions: [
      '타겟 고객이 많이 사는 또는 활동하는 상권을 파악하고 있다',
      '후보 위치의 임대료·권리금·유동인구를 직접 조사해봤다',
      '주변 경쟁 센터 수와 현황을 파악하고 있다'
    ]
  },
  {
    id: 'marketing',
    label: '영역 5',
    title: '모객 계획',
    desc: '오픈 전부터 고객을 모을 방법이 있는가',
    questions: [
      '오픈 전 사전 모객을 어떻게 할지 구체적인 방법이 있다',
      'SNS 또는 온라인 채널로 잠재 고객과 소통하고 있거나 계획이 있다',
      '오픈 첫 달 목표 회원 수와 그 근거가 있다'
    ]
  },
  {
    id: 'operation',
    label: '영역 6',
    title: '운영 구조',
    desc: '수익과 지속 운영의 구조를 이해하는가',
    questions: [
      '손익분기점(몇 명부터 적자를 면하는지)을 계산해본 적 있다',
      '회원 재등록률을 높이는 구체적인 방법을 알고 있다',
      '투자금을 언제까지 회수할지 기간과 계획이 있다'
    ]
  }
];

const SCALE_LABELS = ['전혀 아니다', '그렇다'];

let currentDomain = 0;
let scores = {};

function updateProgress() {
  const total = DOMAINS.length + 1;
  const current = currentDomain + 1;
  const pct = (current / total) * 100;
  document.getElementById('progressBar').style.width = pct + '%';
}

function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0, 0);
}

function startDiagnosis() {
  currentDomain = 0;
  scores = {};
  showDomain(0);
  updateProgress();
}

function showDomain(index) {
  const d = DOMAINS[index];
  document.getElementById('domainLabel').textContent = d.label;
  document.getElementById('domainTitle').textContent = d.title;
  document.getElementById('domainDesc').textContent = d.desc;
  document.getElementById('stepCount').textContent = `${index + 1} / ${DOMAINS.length}`;

  const body = document.getElementById('questionsBody');
  body.innerHTML = '';

  d.questions.forEach((q, qi) => {
    const item = document.createElement('div');
    item.className = 'question-item';
    item.innerHTML = `
      <div class="question-num">Q${qi + 1}</div>
      <div class="question-text">${q}</div>
      <div class="scale-wrap">
        <div class="scale-labels">
          <span class="scale-label-text">전혀 아니다</span>
          <span class="scale-label-text">매우 그렇다</span>
        </div>
        <div class="scale-options">
          ${[1,2,3,4,5].map(v => `
            <button class="scale-btn" data-domain="${d.id}" data-q="${qi}" data-val="${v}" onclick="selectScore(this, '${d.id}', ${qi}, ${v})">${v}</button>
          `).join('')}
        </div>
      </div>
    `;
    body.appendChild(item);
  });

  // Restore previous scores if any
  if (scores[d.id]) {
    scores[d.id].forEach((val, qi) => {
      if (val !== null) {
        const btns = body.querySelectorAll(`[data-domain="${d.id}"][data-q="${qi}"]`);
        btns.forEach(b => {
          if (parseInt(b.dataset.val) === val) b.classList.add('selected');
        });
      }
    });
  } else {
    scores[d.id] = [null, null, null];
  }

  showScreen('screenQuestion');
}

function selectScore(el, domainId, qIndex, val) {
  // Clear siblings
  const siblings = el.parentElement.querySelectorAll('.scale-btn');
  siblings.forEach(b => b.classList.remove('selected'));
  el.classList.add('selected');
  scores[domainId][qIndex] = val;
}

function nextDomain() {
  const d = DOMAINS[currentDomain];
  const domainScores = scores[d.id];

  if (!domainScores || domainScores.some(v => v === null)) {
    showToast('모든 문항에 응답해주세요');
    return;
  }

  currentDomain++;
  if (currentDomain >= DOMAINS.length) {
    showResults();
  } else {
    showDomain(currentDomain);
    updateProgress();
  }
}

function showResults() {
  document.getElementById('progressBar').style.width = '100%';

  let total = 0;
  const domainTotals = {};

  DOMAINS.forEach(d => {
    const sum = scores[d.id].reduce((a, b) => a + b, 0);
    domainTotals[d.id] = sum;
    total += sum;
  });

  // Total score label
  let totalLabel, totalDesc, labelClass;
  if (total <= 30) {
    totalLabel = '창업 준비 초기 단계';
    totalDesc = '아직 준비가 많이 필요합니다. 지금 시작하면 구조 없이 시작하는 것과 같습니다. 부족한 영역을 하나씩 채워야 합니다.';
    labelClass = 'danger';
  } else if (total <= 60) {
    totalDesc = '일부 영역은 준비됐지만 핵심적으로 비어 있는 부분이 있습니다. 그 부분을 채우고 시작해야 합니다.';
    totalLabel = '부분 준비 — 보완 구간 명확';
    labelClass = 'warn';
  } else {
    totalLabel = '창업 준비 완료 — 설계 단계 진입 가능';
    totalDesc = '준비가 잘 되어 있습니다. 이제 구체적인 실행 설계로 넘어갈 단계입니다.';
    labelClass = 'ok';
  }

  // Animate total score
  const totalEl = document.getElementById('totalScoreNum');
  let count = 0;
  const interval = setInterval(() => {
    count += 2;
    if (count >= total) { count = total; clearInterval(interval); }
    totalEl.textContent = count;
  }, 20);

  document.getElementById('totalScoreBar').style.width = (total / 90 * 100) + '%';
  document.getElementById('totalScoreLabel').textContent = totalLabel;
  document.getElementById('totalScoreLabel').className = 'total-score-label ' + labelClass;
  document.getElementById('totalScoreDesc').textContent = totalDesc;

  // Result title
  const firstName = '내 창업 준비도';
  document.getElementById('resultTitle').textContent = firstName;

  // Domain results
  const container = document.getElementById('domainResults');
  container.innerHTML = '';

  DOMAINS.forEach(d => {
    const score = domainTotals[d.id];
    let cls, statusText;
    if (score <= 5) { cls = 'danger'; statusText = '⚠ 창업 전 반드시 보완 필요'; }
    else if (score <= 10) { cls = 'warn'; statusText = '△ 방향은 있으나 구체성 부족'; }
    else { cls = 'ok'; statusText = '✓ 이 영역은 진행 가능'; }

    const pct = (score / 15 * 100).toFixed(0);

    const el = document.createElement('div');
    el.className = 'domain-result-item';
    el.innerHTML = `
      <div class="domain-result-top">
        <span class="domain-result-name">${d.title}</span>
        <span class="domain-result-score ${cls}">${score} / 15</span>
      </div>
      <div class="domain-bar-wrap">
        <div class="domain-bar ${cls}" style="width:0%" data-width="${pct}%"></div>
      </div>
      <div class="domain-status-text ${cls}">${statusText}</div>
    `;
    container.appendChild(el);
  });

  showScreen('screenResult');

  // Animate bars after render
  setTimeout(() => {
    document.querySelectorAll('.domain-bar').forEach(bar => {
      bar.style.width = bar.dataset.width;
    });
  }, 100);
}

function getResultText() {
  let total = 0;
  const lines = ['[OWNERSCAN 창업 전 진단 결과]\n'];

  DOMAINS.forEach(d => {
    const score = scores[d.id] ? scores[d.id].reduce((a, b) => a + b, 0) : 0;
    total += score;
    let status;
    if (score <= 5) status = '⚠ 보완 필요';
    else if (score <= 10) status = '△ 구체성 부족';
    else status = '✓ 준비됨';
    lines.push(`• ${d.title}: ${score}/15점 ${status}`);
  });

  lines.push(`\n총점: ${total}/90점`);

  if (total <= 30) lines.push('→ 창업 준비 초기 단계');
  else if (total <= 60) lines.push('→ 부분 준비 완료, 보완 필요');
  else lines.push('→ 창업 준비 완료');

  lines.push('\n무료 상담 신청: open.kakao.com/o/s6IKh8Ai');
  return lines.join('\n');
}

function openKakao() {
  const name = document.getElementById('inputName').value.trim();
  const phone = document.getElementById('inputPhone').value.trim();

  if (!name || !phone) {
    showToast('이름과 연락처를 입력해주세요');
    return;
  }

  let total = 0;
  const domainScores = {};
  const detailLines = [];

  DOMAINS.forEach(d => {
    const score = scores[d.id] ? scores[d.id].reduce((a, b) => a + b, 0) : 0;
    domainScores[d.id] = score;
    total += score;
    detailLines.push(d.title + ':' + score);
  });

  const params = new URLSearchParams({
    name: name,
    phone: phone,
    total: total,
    customer: domainScores.customer || 0,
    concept: domainScores.concept || 0,
    capital: domainScores.capital || 0,
    location: domainScores.location || 0,
    marketing: domainScores.marketing || 0,
    operation: domainScores.operation || 0,
    detail: detailLines.join(' / ')
  });

  // 새 탭: Apps Script가 데이터 저장 후 카카오로 리다이렉트
  window.open(SCRIPT_URL + '?' + params.toString(), '_blank');
  copyResult(false);
}

function copyResult(showMessage = true) {
  const text = getResultText();
  if (navigator.clipboard) {
    navigator.clipboard.writeText(text).then(() => {
      if (showMessage) showToast('결과가 복사됐습니다');
    });
  } else {
    const ta = document.createElement('textarea');
    ta.value = text;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    if (showMessage) showToast('결과가 복사됐습니다');
  }
  if (!showMessage) showToast('결과가 복사됐습니다. 카카오에 붙여넣기 해주세요');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

function restartDiagnosis() {
  currentDomain = 0;
  scores = {};
  document.getElementById('progressBar').style.width = '0%';
  showScreen('screenIntro');
}
</script>
